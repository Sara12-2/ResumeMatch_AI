# Optional - only needed for the narrative suggestions layer
# (src/recommender.py). The score, skill gap, and section ranking all work
# fully without this configured.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Optional - web/app.py falls back to sensible defaults if unset
PORT=5000
FLASK_DEBUG=false
